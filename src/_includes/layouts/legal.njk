---
layout: layouts/base.njk
bodyClass: has-nav-logo
footerType: simple
---
<main id="main" class="article-wrapper">
  <header class="article-header">
    <span class="article-date">Legal</span>
    <h1 class="article-title">{{ title }}</h1>
    <div class="article-gold-line"></div>
  </header>

  <div class="article-body">
    {{ content | safe }}

    <a href="{{ '/' | url }}" class="article-back">&larr; Back to home</a>
  </div>
</main>
