        <span class="testimonial-name">Jean-Pierre Muller</span>
        <span class="testimonial-project" data-fr="Rénovation patrimoniale — Grund" data-de="Denkmalsanierung — Grund" data-en="Heritage Renovation — Grund" data-lb="Patrimoine Renovéierung — Grond">Heritage Renovation — Grund</span>
      </div>
